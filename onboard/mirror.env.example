# Copy this file to `onboard/mirror.env`, then adjust the values you want.
# `onboard/env.sh` will load it automatically.

# Optional: point the helper scripts at a different local lancedb checkout.
# export LANCEDB_REPO="/absolute/path/to/lancedb"

# Optional: use a PyPI mirror.
# TUNA pip guide:
# https://mirrors.tuna.tsinghua.edu.cn/help/pypi/
export PIP_INDEX_URL="https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple"

# Optional: if you already use extra package indexes, keep them here.
# The build script will automatically append the required Fury indexes for lance.
# export PIP_EXTRA_INDEX_URL="https://example.com/simple"

# Optional: mirror uv's package index settings to match pip.
export UV_DEFAULT_INDEX="https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple/"

# Optional: increase resilience for uv-managed downloads.
export UV_HTTP_TIMEOUT=120
export UV_HTTP_RETRIES=5

# Optional: use a mirror for uv-managed Python downloads.
# This must mirror Astral python-build-standalone releases.
# export UV_PYTHON_INSTALL_MIRROR="https://your-mirror.example/python-build-standalone/releases/download"

# Optional: use a Rustup mirror.
# TUNA rustup guide:
# https://mirrors.tuna.tsinghua.edu.cn/help/rustup/
export RUSTUP_DIST_SERVER="https://mirrors.tuna.tsinghua.edu.cn/rustup"
export RUSTUP_UPDATE_ROOT="https://mirrors.tuna.tsinghua.edu.cn/rustup/rustup"

# Optional: override the rustup installer script URL.
# export RUSTUP_INIT_URL="https://your-mirror.example/rustup-init.sh"

# Optional: use a mirror for the protoc zip download.
# Keep the filename compatible with PROTOC_VERSION / PROTOC_ARCHIVE_NAME.
# export PROTOC_DOWNLOAD_URL="https://your-mirror.example/protobuf/releases/download/v34.1/protoc-34.1-linux-x86_64.zip"

# Optional: tune network retries for curl / pip.
export CURL_RETRY_COUNT=5
export PIP_INSTALL_RETRIES=10
export PIP_INSTALL_TIMEOUT=120
