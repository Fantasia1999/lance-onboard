# Copy this file to `onboard/minio.env`, then adjust the values if needed.

export MINIO_ROOT_USER="ACCESSKEY"
export MINIO_ROOT_PASSWORD="SECRETKEY"
export MINIO_HOST="127.0.0.1"
export MINIO_PORT="9000"
export MINIO_CONSOLE_PORT="9001"
export MINIO_REGION="us-east-1"
export MINIO_BUCKET="lancedb-dev"
export MINIO_ALIAS="pgsty"

# Optional: pin specific fork releases instead of using the latest GitHub release.
# export PGSTY_MINIO_RELEASE="RELEASE.2026-03-25T00-00-00Z"
# export PGSTY_MC_RELEASE="RELEASE.2026-03-21T00-00-00Z"

# Optional: override where local runtime artifacts are stored.
# export LOCAL_ROOT="/absolute/path/to/local"
